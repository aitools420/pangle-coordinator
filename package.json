{
  "name": "pangle-coordinator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pangle MVP — swarm coordinator + MCP server for the On-Chain Intelligence Chain (Phase 0).",
  "engines": { "node": ">=22" },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "e2e": "tsx scripts/e2e-smoke.ts",
    "agent-sim": "tsx scripts/agent-sim.ts",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vvv",
    "deploy:local": "bash scripts/deploy-local.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "express": "^4.21.2",
    "viem": "^2.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
