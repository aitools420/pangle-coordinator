# ── Coordinator ───────────────────────────────────────────────
PORT=8920
NODE_ENV=development
# Authentication is chain-agnostic off-chain ECDSA — there is NO shared secret to configure. Agents
# sign a login statement (and every contribution) with their own key; the coordinator verifies by
# recovering the signer (EIP-191), with no on-chain call and no specific chain. ERC-8004 identity is
# optional. See src/auth.ts.
# Max lifetime of a session auth-assertion (the self-signed bearer token), in seconds.
SESSION_TTL_SECONDS=1800
# Admin API key (x-admin-key header). REQUIRED when NODE_ENV != development (no default in prod).
# Generate a strong value: `openssl rand -hex 24`.
ADMIN_KEY=
# Public base URL the MCP server is reached at — the audience bound into the signed login
# statement (an RFC-8707 resource indicator), so a token can't be replayed against another server.
MCP_RESOURCE_URL=http://localhost:8920/mcp

# ── Chain ─────────────────────────────────────────────────────
# local   = anvil (chainId 31337), dev key below
# mainnet = PulseChain mainnet (chainId 369) — production target (no testnet stage)
CHAIN_MODE=local
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
# The coordinator wallet: sole scorer, token minter, reputation-anchor writer.
# Value below is the well-known anvil account #0 — LOCAL DEV ONLY, never use on a real chain.
COORDINATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Contract addresses (populated by scripts/deploy-local.sh) ──
IDENTITY_REGISTRY_ADDRESS=
PANGLE_TOKEN_ADDRESS=
REPUTATION_ANCHOR_ADDRESS=

# ── Intelligence Chain ────────────────────────────────────────
SYNTHESIS_WINDOW_HOURS=48

# ── Storage ───────────────────────────────────────────────────
DB_PATH=./data/pangle.db
